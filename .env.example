# 复制此文件为 .env，填入真实密钥（.env 已被 .gitignore 忽略，不会上传到 GitHub）
KIMI_API_KEY=your_kimi_api_key_here
TG_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here

# 可选：日报的 Kimi 模型（默认已是最优组合，一般不用改）
# 分析/整理任务用 kimi-k3；联网搜索任务用 kimi-k2.6（k3 暂不支持 $web_search）
# KIMI_MODEL=kimi-k3
# KIMI_SEARCH_MODEL=kimi-k2.6

# DeepSeek 问答（tg_bot.py 的 /ask 与 @问答用；不填则该功能关闭）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 可选：默认 deepseek-v4-pro
# DEEPSEEK_MODEL=deepseek-v4-pro

# 可选：机器人额外响应的会话白名单（逗号分隔的 chat_id 或 @username）
# TG_ALLOWED_CHATS=
